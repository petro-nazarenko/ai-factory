# Groq API key (primary LLM provider — faster and cheaper)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic API key (fallback if GROQ_API_KEY is absent)
ANTHROPIC_API_KEY=sk-ant-...

# Reddit API credentials (optional – enables Reddit signal mining)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=MoneymakerBot/1.0

# Product Hunt API token (optional – enables Product Hunt signal mining)
PRODUCTHUNT_TOKEN=

# Minimum score (0–10) a signal must reach to be passed to the idea generator
SIGNAL_MIN_SCORE=6

# Maximum number of ideas to generate per signal
IDEAS_PER_SIGNAL=3

# Anthropic model to use for generation / scoring
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Distribution ---

# Reddit subreddit to post distribution content to (default: indiehackers)
REDDIT_DISTRIBUTION_SUBREDDIT=indiehackers

# Twitter / X Bearer Token (required for Twitter distribution)
TWITTER_BEARER_TOKEN=

# Telegram Bot Token and Channel ID (required for Telegram distribution)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@yourchannel

# --- Deployment ---

# Vercel token for deploying landing pages (get at vercel.com/account/tokens)
VERCEL_TOKEN=
# Vercel team ID (optional, leave empty for personal accounts)
VERCEL_TEAM_ID=

# --- Autonomous loop ---

# Hours between pipeline cycles (default: 24)
LOOP_INTERVAL_HOURS=24

# Max pain signals to mine per cycle (default: 40)
LOOP_SIGNAL_LIMIT=40

# SQLite memory path inside container (default: data/memory.db)
DB_PATH=data/memory.db

# --- Infrastructure (v5 swarm) ---

# PostgreSQL (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/moneymaker

# Redis (broker + result backend)
REDIS_URL=redis://redis:6379/0
